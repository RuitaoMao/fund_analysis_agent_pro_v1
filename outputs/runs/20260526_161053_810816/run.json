{
  "query": "这些基金都持有哪些共同的股票",
  "session_id": "demo-memory-1",
  "mode": "llm",
  "plan": {
    "intent": "generated_sql_query",
    "tool_name": "generated_sql_query",
    "args": {
      "sql": "SELECT stock_name AS 股票名称, stock_code AS 股票代码, COUNT(DISTINCT fund_code) AS 持有基金数, ROUND(SUM(holding_value)/1e8,2) AS 持仓总市值_亿元, ROUND(AVG(nav_ratio),2) AS 平均净值占比_pct FROM fund_holding WHERE date = (SELECT MAX(date) FROM fund_holding) GROUP BY stock_name, stock_code HAVING COUNT(DISTINCT fund_code) >= 2 ORDER BY 持有基金数 DESC, 持仓总市值_亿元 DESC LIMIT 200",
      "tables": [
        "fund_holding"
      ]
    },
    "tool_calls": [],
    "answer_type": "report",
    "need_clarification": false,
    "clarification_question": null,
