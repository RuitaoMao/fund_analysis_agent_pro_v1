# =========================
# Agent runtime
# =========================
AGENT_MODE=llm
# DB 在项目目录内（data/processed/fund_agent.db）
# 项目已从 OneDrive 移至 D:\ 盘，无同步锁定风险

SQLITE_DB_PATH=data/processed/fund_agent.db
# =========================
# Hard mode planner
# 用于 hard 模式：选择已有 tools，不直接写 SQL
# =========================
PLANNER_PROVIDER=deepseek
PLANNER_MODEL=deepseek-v4-pro
PLANNER_THINKING_ENABLED=false

# OpenAI alternative:
# PLANNER_PROVIDER=openai
# PLANNER_MODEL=gpt-5.4-mini
# PLANNER_THINKING_ENABLED=false

# =========================
# Generated SQL planner
# 用于 generated 模式：LLM 生成受控 SQL
# 建议开启 thinking
# =========================
SQL_PROVIDER=deepseek
SQL_MODEL=deepseek-v4-pro
SQL_THINKING_ENABLED=true

# OpenAI alternative:
# SQL_PROVIDER=openai
# SQL_MODEL=gpt-5.4
# SQL_THINKING_ENABLED=false

# =========================
# Report writer
# 用于最终中文报告写作
# =========================
REPORT_PROVIDER=deepseek
REPORT_MODEL=deepseek-v4-pro
# 必须保持 false：thinking=true 时 deepseek-v4-pro 会把全部 max_tokens 预算用于推理，
# 复杂报告（>200 行数据）的 content 经常返回空串，造成"最终回答为空"。
REPORT_THINKING_ENABLED=false

# OpenAI alternative:
# REPORT_PROVIDER=openai
# REPORT_MODEL=gpt-5.4-mini
# REPORT_THINKING_ENABLED=false

# =========================
# DeepSeek
# =========================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek V4 Pro thinking effort:
# high: 推荐默认
# max: 更强但更慢/更贵，适合复杂 generated SQL 评测
DEEPSEEK_REASONING_EFFORT=high
# 关闭：当前 Outliner 在复杂报告中几乎总是失败回退到 skill_fallback，
# 白白浪费约 25s/题。skill 模板大纲已足够驱动 Drafter。
REPORT_OUTLINER_ENABLED=false
# =========================
# OpenAI
# 保留以后切换用；官方 API 的 OPENAI_BASE_URL 留空
# =========================
OPENAI_API_KEY=你的OpenAIKey
OPENAI_BASE_URL=

# =========================
# Compatible OpenAI-style provider
# 例如 OpenRouter / Qwen / 自定义网关，暂时不用可留空
# =========================
COMPATIBLE_API_KEY=
COMPATIBLE_BASE_URL=