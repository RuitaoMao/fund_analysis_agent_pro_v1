# ===== 运行模式 =====
# mock：不调用外部 LLM，适合学习/测试
# llm：调用真实 LLM API
AGENT_MODE=mock

# ===== Planner LLM =====
# 可填 openai / deepseek / compatible
PLANNER_PROVIDER=openai
PLANNER_MODEL=gpt-4.1-nano
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=

# ===== Report Writer LLM =====
REPORT_PROVIDER=deepseek
REPORT_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== OpenAI-compatible 备用供应商 =====
# 例如 Qwen / OpenRouter / 硅基流动等兼容 Chat Completions 的服务。
# 使用时把 PLANNER_PROVIDER 或 REPORT_PROVIDER 设置为 compatible。
COMPATIBLE_API_KEY=your_compatible_api_key
COMPATIBLE_BASE_URL=https://example-compatible-endpoint/v1

# ===== 数据库 =====
SQLITE_DB_PATH=data/processed/fund_agent.db
